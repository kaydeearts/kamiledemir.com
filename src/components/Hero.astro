---
import '../styles/hero.css';
import { readdir } from 'fs/promises';
import { join } from 'path';

const heroDir = join(process.cwd(), 'public/images/hero');
const files = await readdir(heroDir);
const images = files
  .filter(f => /\.(jfif|jpg|jpeg|png|webp|gif)$/i.test(f))
  .map(f => `/images/hero/${f}`);
---

<section id="hero" class="hero">
  <div class="hero__inner">
    <div class="hero__text">
      <p class="hero__greeting">Hi!</p>
      <p class="hero__name">I'm Kamilé</p>
      <p class="hero__tagline">Engineering at the intersection of art & technology</p>
    </div>
    <div class="hero__photos">
      <img class="hero__photo hero__photo--1" src="" alt="" />
      <img class="hero__photo hero__photo--2" src="" alt="" />
      <img class="hero__photo hero__photo--3" src="" alt="" />
    </div>
  </div>
</section>

<script define:vars={{ images }}>
  // Preload all images so swaps are instant
  images.forEach(src => { const img = new Image(); img.src = src; });

  // Shuffle once per page load so each visit starts at a different point
  for (let i = images.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [images[i], images[j]] = [images[j], images[i]];
  }

  const slots = Array.from(document.querySelectorAll('.hero__photo'));
  const current = slots.map((slot, i) => {
    slot.src = images[i];
    return i;
  });

  function getNextIndex(slotIndex) {
    const showing = new Set(current);
    let next = (current[slotIndex] + 1) % images.length;
    while (showing.has(next) && next !== current[slotIndex]) {
      next = (next + 1) % images.length;
    }
    return next;
  }

  const FADE_DURATION = 1200;
  const HOLD_DURATION = 3000;

  function swapNext(slotIndex) {
    const slot = slots[slotIndex];
    slot.classList.add('is-swapping');
    setTimeout(() => {
      current[slotIndex] = getNextIndex(slotIndex);
      slot.src = images[current[slotIndex]];
      slot.classList.remove('is-swapping');
      setTimeout(() => {
        swapNext((slotIndex + 1) % slots.length);
      }, HOLD_DURATION);
    }, FADE_DURATION);
  }

  setTimeout(() => swapNext(0), 4000);
</script>
